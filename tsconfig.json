{
  "compilerOptions": {
    "outDir": "./dist",
    "moduleResolution": "node",
    "composite": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "esnext",
    "target": "es6",
    "strict": true,
    "lib": ["DOM", "ESNext"],
    "types": ["jest", "node"]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/types/global.d.ts"
  ],
  "exclude": ["node_modules"]
}
